<%- include("../partials/navbar") %>
<%- include("../partials/alert") %>

<section class="container mt-4">
  <legend class="mb-0">All Bookings</legend>
  <p class="text-secondary">
    Tap a booking to view details
  </p>
  <div class="d-flex justify-content-end">

    <!-- Button trigger modal -->
    <button type="button" class="btn btn-secondary align-self-left" data-bs-toggle="modal" data-bs-target="#filterModal" >
    <i class="bi bi-funnel"></i> Filter
    </button>

    <!-- Modal -->
    <div class="modal fade" id="filterModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h1 class="modal-title fs-5" id="exampleModalLabel">Filters</h1>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form method="GET" action="/booking/view" class="d-flex flex-column mt-2">
                    <div class="modal-body ">

                        <!-- Occupation -->
                        <div>
                        <label class="form-label">Occupation</label>
                        <select name="occupation" class="form-select">
                            <option value="">All</option>
                            <option value="Railway" <%= query?.occupation === "Railway" ? "selected" : "" %>>Railway</option>
                            <option value="Committee" <%= query?.occupation === "Committee" ? "selected" : "" %>>Committee</option>
                            <option value="Others" <%= query?.occupation === "Others" ? "selected" : "" %>>Others</option>
                        </select>
                        </div>

                        <!-- Date -->
                        <div>
                        <label class="form-label">Date</label>
                        <input 
                            type="date" 
                            name="date" 
                            value="<%= query?.date || "" %>" 
                            class="form-control"
                        />
                        </div>

                        <!-- Entity -->
                        <div>
                        <label class="form-label">Entity</label>
                        <input 
                            type="text" 
                            name="entity" 
                            placeholder="Hall / Room" 
                            value="<%= query?.entity || "" %>"
                            class="form-control"
                        />
                        </div>

                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-primary">
                            Apply
                        </button>
                        <a href="/booking/view" class="btn btn-outline-secondary">
                            Reset
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
  </div>


  <!-- Desktop Table -->
  <div class="table-responsive d-none d-md-block mt-3">
    <table class="table table-hover align-middle">
      <thead>
        <tr>
          <th>Name</th>
          <th>Date</th>
          <th>Occupation</th>
          <th>Entities</th>
          <th class="text-end">Total</th>
        </tr>
      </thead>
      <tbody>
        <% response.forEach(element => { %>
          <tr>
            <td>
              <a href="/booking/view/<%= element._id %>" class="fw-semibold text-decoration-none">
                <%= element.name %>
              </a>
            </td>
            <td><%= new Date(element.date).toLocaleDateString() %></td>
            <td>
              <span class="badge bg-<%= 
  element.occupation === "Railway" ? "primary" :
  element.occupation === "Committee" ? "success" :
  element.occupation === "Others" ? "secondary" :
  "secondary"%>">
                <%= element.occupation %>
              </span>
            </td>
            <td><%= element.entities.length %></td>
            <td class="text-end fw-semibold">
              ₹ <%= element.totalPrice %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- Mobile Cards -->
  <div class="d-md-none mt-3">
    <% response.forEach(element => { %>
      <div class="card shadow-sm mb-3">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start">
            <div>
              <h6 class="mb-1">
                <a href="/booking/view/<%= element._id %>" class="text-decoration-none">
                  <%= element.name %>
                </a>
              </h6>
              <small class="text-muted">
                <%= new Date(element.date).toLocaleDateString() %>
              </small>
            </div>
            <span class="badge bg-<%= 
  element.occupation === "Railway" ? "primary" :
  element.occupation === "Committee" ? "success" :
  element.occupation === "Others" ? "secondary" :
  "secondary"%>">
              <%= element.occupation %>
            </span>
          </div>

          <hr class="my-2">

          <div class="d-flex justify-content-between">
            <span class="text-muted">Entities</span>
            <span><%= element.entities.length %></span>
          </div>

          <div class="d-flex justify-content-between fw-semibold">
            <span>Total</span>
            <span>₹ <%= element.totalPrice %></span>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</section>