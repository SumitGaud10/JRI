<%- include("../partials/navbar") %>
<%- include("../partials/alert") %>

<section class="container mt-4">
    <a href="/booking/view" >
      ← Back to Bookings
    </a>
    <div class="mt-2">
      <legend class="mb-0"><%= booking.name %></legend>
      <p class="text-secondary mb-0">Booking Details</p>
    </div>


  <hr class="my-4" />

  <!-- Booking Info Card -->
  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <div class="row mb-2">
        <div class="col-md-3 fw-semibold">Date</div>
        <div class="col-md-9">
          <%= new Date(booking.date).toLocaleDateString() %>
        </div>
      </div>

      <div class="row mb-2">
        <div class="col-md-3 fw-semibold">Occupation</div>
        <div class="col-md-9">
          <span class="badge bg-primary">
            <%= booking.occupation %>
          </span>
        </div>
      </div>

      <div class="row">
        <div class="col-md-3 fw-semibold">Booked By</div>
        <div class="col-md-9">
          <%= booking.bookedBy %>
        </div>
      </div>
    </div>
  </div>

  <!-- Entities Table -->
  <div class="card shadow-sm">
    <div class="card-body">
      <h5 class="mb-3">Booked Entities</h5>

      <table class="table table-striped align-middle">
        <thead>
          <tr>
            <th>#</th>
            <th>Entity Name</th>
            <th class="text-end">Price (₹)</th>
          </tr>
        </thead>
        <tbody>
          <% 
            booking.entities.forEach((entity, index) => { 
          %>
            <tr>
              <td><%= index + 1 %></td>
              <td><%= entity.name %></td>
              <td class="text-end"><%= entity.price %></td>
            </tr>
          <% }) %>
        </tbody>
        <tfoot>
          <tr class="fw-semibold">
            <td colspan="2" class="text-end">Total</td>
            <td class="text-end">
              ₹ <%= booking.totalPrice %>
            </td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>

  <!-- Button trigger modal -->
<button type="button" class="btn btn-danger mt-4" data-bs-toggle="modal" data-bs-target="#exampleModal">
    Delete Booking
</button>

<!-- Modal -->
<div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h1 class="modal-title fs-5" id="exampleModalLabel">Confirmantion</h1>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        Are you sure? This action is irreverseable 
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        <form method="post" action="/booking/delete/<%= booking._id %>">
            
            <button type="submit" class="btn btn-danger">Delete</button>
            </form>
      </div>
    </div>
  </div>
</div>
</section>