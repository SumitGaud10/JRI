<%- include("../partials/navbar") %> <%- include("../partials/alert") %>
<section class="container mt-4">
  <a href="/admin"> ← Back to admin page </a>
  <div class="mt-2">
    <legend class="mb-0"><%= information.username %></legend>
    <p class="text-secondary mb-0">User Details</p>
  </div>

  <div class="card shadow-sm mt-4">
    <div class="card-body">
      <div class="row mb-2">
        <div class="col-md-3 fw-semibold">Username</div>
        <div class="col-md-9"><%= information.username %></div>
      </div>

      <div class="row mb-2">
        <div class="col-md-3 fw-semibold">Role</div>
        <div class="col-md-9">
          <span class="badge bg-primary"> <%= information.role %> </span>
        </div>
      </div>

      <div class="row">
        <div class="col-md-3 fw-semibold">Created At</div>
        <div class="col-md-9"><%= information.createdAt %></div>
      </div>

      <div class="row">
        <div class="col-md-3 fw-semibold">Last Updated At</div>
        <div class="col-md-9"><%= information.updatedAt %></div>
      </div>

      <div class="mt-3 d-flex justify-content-end align-items-end gap-2">
        <!-- Button trigger modal -->
        <button
          type="button"
          class="btn btn-primary"
          data-bs-toggle="modal"
          data-bs-target="#userPasswordChange"
        >
          Change Password
        </button>

        <!-- Modal -->
        <div
          class="modal fade"
          id="userPasswordChange"
          tabindex="-1"
          aria-labelledby="exampleModalLabel"
          aria-hidden="true"
        >
          <div class="modal-dialog">
            <div class="modal-content">
              <div class="modal-header">
                <h1 class="modal-title fs-5" id="exampleModalLabel">
                  Change Password
                </h1>
                <button
                  type="button"
                  class="btn-close"
                  data-bs-dismiss="modal"
                  aria-label="Close"
                ></button>
              </div>
              <form
                action="/admin/user/passwd/<%= information._id %>"
                method="post"
              >
                <div class="modal-body">
                  <div class="mb-3">
                    <label for="newPassword" class="form-label"
                      >New Password</label
                    >
                    <input
                      type="password"
                      class="form-control"
                      id="newPassword"
                      name="newPassword"
                    />
                  </div>
                </div>
                <div class="modal-footer">
                  <button
                    type="button"
                    class="btn btn-secondary"
                    data-bs-dismiss="modal"
                  >
                    Close
                  </button>
                  <button type="submit" class="btn btn-primary">
                    Save changes
                  </button>
                </div>
              </form>
            </div>
          </div>
        </div>
        <button
          type="button"
          class="btn btn-danger"
          data-bs-toggle="modal"
          data-bs-target="#deleteUser"
        >
          Delete User
        </button>

        <!-- Modal -->
        <div
          class="modal fade"
          id="deleteUser"
          tabindex="-1"
          aria-labelledby="exampleModalLabel"
          aria-hidden="true"
        >
          <div class="modal-dialog">
            <div class="modal-content">
              <div class="modal-header">
                <h1 class="modal-title fs-5" id="exampleModalLabel">
                  Confirmantion
                </h1>
                <button
                  type="button"
                  class="btn-close"
                  data-bs-dismiss="modal"
                  aria-label="Close"
                ></button>
              </div>
              <div class="modal-body">
                Are you sure? This action is irreverseable
              </div>
              <div class="modal-footer">
                <button
                  type="button"
                  class="btn btn-secondary"
                  data-bs-dismiss="modal"
                >
                  Close
                </button>
                <form method="post" action="/admin/user/<%= information._id %>">
                  <button type="submit" class="btn btn-danger">Delete</button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
