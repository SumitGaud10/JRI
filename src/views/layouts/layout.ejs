<!doctype html>
<html lang="en" data-bs-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Booking System | JRI</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://cdn.datatables.net/2.3.7/css/dataTables.dataTables.min.css"
    />
  </head>
  <body>
    <%- body %>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"
    ></script>
    <script>
      const themeToggler = document.getElementById("theme-toggle");
      const doc = document.querySelector("html");
      let currentTheme = localStorage.getItem("theme");

      if (!currentTheme) {
        localStorage.setItem("theme", "light");
        currentTheme = "light";
      }
      doc.setAttribute("data-bs-theme", currentTheme);

      themeToggler.addEventListener("click", (event) => {
        const newTheme = currentTheme == "light" ? "dark" : "light";
        localStorage.setItem("theme", newTheme);
        doc.setAttribute("data-bs-theme", newTheme);
        currentTheme = newTheme;
      });
    </script>
  </body>
</html>
